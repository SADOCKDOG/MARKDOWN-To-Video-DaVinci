{
	Tools = ordered() {
		Background1 = Background {
			Inputs = {
				Width = Input { Value = 1920, },
				Height = Input { Value = 1080, },
				Alpha = Input { Value = 0, },
				[ "EffectMask" ] = Input { },
			},
			ViewInfo = OperatorInfo { Pos = { -330, 0 } },
		},
		MainTitle = TextPlus {
			Inputs = {
				StyledText = Input { Value = "TITULO PRINCIPAL", },
				Font = Input { Value = "Arial", },
				Size = Input { Value = 0.12, },
				Center = Input { Value = { 0.5, 0.39 }, },
				[ "EffectMask" ] = Input { },
			},
			ViewInfo = OperatorInfo { Pos = { -170, 0 } },
		},
		Merge1 = Merge {
			Inputs = {
				Background = Input { SourceOp = "Background1", Source = "Output", },
				Foreground = Input { SourceOp = "MainTitle", Source = "Output", },
			},
			ViewInfo = OperatorInfo { Pos = { 10, 0 } },
		},
		SubTitle = TextPlus {
			Inputs = {
				StyledText = Input { Value = "Subtitulo editorial", },
				Font = Input { Value = "Arial", },
				Size = Input { Value = 0.045, },
				Center = Input { Value = { 0.5, 0.49 }, },
				[ "EffectMask" ] = Input { },
			},
			ViewInfo = OperatorInfo { Pos = { -170, 72 } },
		},
		Merge2 = Merge {
			Inputs = {
				Background = Input { SourceOp = "Merge1", Source = "Output", },
				Foreground = Input { SourceOp = "SubTitle", Source = "Output", },
			},
			ViewInfo = OperatorInfo { Pos = { 10, 72 } },
		},
		MediaOut1 = MediaOut {
			Inputs = {
				Input = Input { SourceOp = "Merge2", Source = "Output", },
			},
			ViewInfo = OperatorInfo { Pos = { 180, 0 } },
		}
	}
}
