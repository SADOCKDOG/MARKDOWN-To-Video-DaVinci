{
	Tools = ordered() {
		Background1 = Background {
			Inputs = {
				Width = Input { Value = 1920, },
				Height = Input { Value = 1080, },
				Alpha = Input { Value = 0, },
				[ "EffectMask" ] = Input { },
			},
			ViewInfo = OperatorInfo { Pos = { -330, 0 } },
		},
		OverlayLabel = TextPlus {
			Inputs = {
				StyledText = Input { Value = "Referencia documental", },
				Font = Input { Value = "Arial", },
				Size = Input { Value = 0.038, },
				Center = Input { Value = { 0.2, 0.13 }, },
				[ "EffectMask" ] = Input { },
			},
			ViewInfo = OperatorInfo { Pos = { -170, 0 } },
		},
		Merge1 = Merge {
			Inputs = {
				Background = Input { SourceOp = "Background1", Source = "Output", },
				Foreground = Input { SourceOp = "OverlayLabel", Source = "Output", },
			},
			ViewInfo = OperatorInfo { Pos = { 10, 0 } },
		},
		OverlayDetail = TextPlus {
			Inputs = {
				StyledText = Input { Value = "Dato de apoyo o contexto visual", },
				Font = Input { Value = "Arial", },
				Size = Input { Value = 0.028, },
				Center = Input { Value = { 0.23, 0.18 }, },
				[ "EffectMask" ] = Input { },
			},
			ViewInfo = OperatorInfo { Pos = { -170, 72 } },
		},
		Merge2 = Merge {
			Inputs = {
				Background = Input { SourceOp = "Merge1", Source = "Output", },
				Foreground = Input { SourceOp = "OverlayDetail", Source = "Output", },
			},
			ViewInfo = OperatorInfo { Pos = { 10, 72 } },
		},
		MediaOut1 = MediaOut {
			Inputs = {
				Input = Input { SourceOp = "Merge2", Source = "Output", },
			},
			ViewInfo = OperatorInfo { Pos = { 180, 0 } },
		}
	}
}
